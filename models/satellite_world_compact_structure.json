{
  "schemaVersion": "1.0.0",
  "modelId": "satellite_world",
  "modelName": "Satellite World",
  "description": "Complete satellite-domain JSON structure covering launches, space objects, satellites, TLEs, orbit states, tracking, operations, conjunctions, decay, reentry, debris, and provenance.",
  "units": {
    "time": "UTC ISO-8601",
    "distance": "km",
    "length": "m",
    "mass": "kg",
    "angle": "deg",
    "velocity": "m/s",
    "frequency": "MHz"
  },
  "visualizationRules": {
    "nodeAttributeLayout": "red hub -> black fan-out lines -> vertical black marker stack -> attribute text",
    "linkEndpointRule": "hub-to-hub only",
    "linkRouting": "orthogonal process-flow",
    "arrowheadRule": "arrowhead attached to target hub",
    "labelRule": "label placed on longest clear route segment"
  },
