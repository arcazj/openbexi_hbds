{
  "$schema": "https://openbexi.local/hbds/model/v2",
  "metadata": {
    "id": "semex_model",
    "name": "HBDS Semantic Object Layer Example",
    "version": "2026.07.18-semantic-v1",
    "purpose": "Provide a loadable HBDS semanticVersion 1 example covering objects, object links, memberships, inheritance, functor traversal, and optional semantic profiles.",
    "semanticVersion": 1,
    "semanticProfiles": {
      "units": { "enabled": true },
      "temporal": { "enabled": true },
      "geospatial": { "enabled": true },
      "fuzzy": { "enabled": true },
      "prototype": { "enabled": true }
    },
    "preserveLayout": true,
    "layout": {
      "algorithm": "none",
      "fit": { "padding": 1.18 }
    },
    "font": {
      "size": 18,
      "family": "Arial, sans-serif",
      "bold": false,
      "italic": false,
      "underline": false,
      "classSize": 20,
      "hyperclassSize": 22,
      "attributeSize": 14,
      "linkSize": 15
    },
    "sceneSettings": {
      "background": "#F8FAFC",
      "ambient": 0.78,
      "front": 0.18,
      "sources": [
        {
          "intensity": 0.18,
          "direction": { "x": -6, "y": 8, "z": 14 }
        },
        {
          "intensity": 0.12,
          "direction": { "x": 8, "y": -5, "z": 11 }
        }
      ]
    },
    "semanticExamples": {
      "functorQueries": [
        {
          "id": "semex_query_direct",
          "name": "Direct satellite to ground site",
          "query": {
            "startObjectIds": ["semex_obj_satellite_alpha"],
            "steps": [
              { "kind": "direct", "classLinkId": "semex_link_communicates" }
            ]
          },
          "expectedObjectIds": ["semex_obj_site_east"]
        },
        {
          "id": "semex_query_inverse",
          "name": "Inverse ground site to satellite",
          "query": {
            "startObjectIds": ["semex_obj_site_east"],
            "steps": [
              { "kind": "inverse", "classLinkId": "semex_link_communicates" }
            ]
          },
          "expectedObjectIds": ["semex_obj_satellite_alpha"]
        },
        {
          "id": "semex_query_homogeneous",
          "name": "Homogeneous ground-site relay",
          "query": {
            "startObjectIds": ["semex_obj_site_east"],
            "steps": [
              { "kind": "homogeneous", "classLinkId": "semex_link_relays", "direction": "both" }
            ]
          },
          "expectedObjectIds": ["semex_obj_site_west"]
        },
        {
          "id": "semex_query_composed",
          "name": "Mission through satellite to ground site",
          "query": {
            "startObjectIds": ["semex_obj_mission_demo"],
            "steps": [
              {
                "kind": "chain",
                "steps": [
                  { "kind": "direct", "classLinkId": "semex_link_assigns" },
                  { "kind": "direct", "classLinkId": "semex_link_communicates" }
                ]
              }
            ]
          },
          "expectedObjectIds": ["semex_obj_site_east"]
        }
      ]
    },
    "regressionTags": [
      "semantic",
      "object-layer",
      "functors",
      "profiles",
      "example"
    ]
  },
  "hypergraph": {
    "class": [
      {
        "id": "semex_hc_mission_domain",
        "name": "Mission Domain",
        "type": "hyperclass",
        "position": { "x": -3.75, "y": 0, "z": 0 },
        "size": { "width": 11, "height": 8 },
        "attributes": [
          { "id": "semex_hc_mission_attr_scope", "name": "operational scope" }
