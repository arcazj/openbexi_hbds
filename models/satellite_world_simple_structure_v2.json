      "sources": [
        {
          "path": "tle/TLE.json",
          "mapsTo": [
            "Cataloged Space Object",
            "Catalog Group",
            "Orbital Element Set"
          ],
          "joinKey": "norad_id"
        },
        {
          "path": "tle/TLE.meta.json",
          "mapsTo": [
            "model provenance"
          ],
          "joinKey": null
        },
        {
          "path": "tle/satellite_launch_dates.json",
          "mapsTo": [
            "Cataloged Space Object"
          ],
          "joinKey": "norad_id"
        },
        {
          "path": "decayed/decayed.json",
          "mapsTo": [
            "Cataloged Space Object"
          ],
          "joinKey": "NORAD_CAT_ID"
        },
        {
          "path": "tle/starlink_launch_date_audit.json",
          "mapsTo": [
            "Launch Event"
          ],
          "joinKey": "unresolved payload references"
        },
        {
          "path": "satellites/*.json",
          "mapsTo": [
            "Satellite Platform Profile",
            "Communication Payload",
            "Organization"
          ],
          "joinKey": "meta.norad_id"
        },
        {
          "path": "ops/ops.json",
          "mapsTo": [
            "Ground Facility",
            "Network Connection"
          ],
          "joinKey": "centers.id"
        },
        {
          "path": "ops/ttc.json",
          "mapsTo": [
            "Ground Facility"
          ],
          "joinKey": "sites.id"
        },
        {
          "path": "display_satellite_models.json",
          "mapsTo": [
            "Display Asset"
          ],
          "joinKey": "models.id"
        },
        {
          "path": "stars/brightStars.json",
          "mapsTo": [
            "Reference Star"
          ],
          "joinKey": "name"
        }
      ],
      "excludedSources": [
        "satellites/satellite_template.json",
        "satellites/0.json",
        "starts/brightStars.json duplicate",
        "backup files",
        "satcat.csv outside the JSON-only scope"
      ]
    },
    "modelingNotes": [
      "Hyperclasses are visual groups and do not assert HBDS inheritance.",
      "Each source row is a future object; no source row is represented as a class.",
      "NORAD identifiers must be normalized to strings before joining datasets.",
      "TLE company is modeled as a catalog group because it is not reliably an operator or constellation.",
      "Decayed records must be joined by NORAD_CAT_ID rather than their object-name map keys.",
      "Launch payload, rocket, and launchpad references remain unresolved external identifiers.",
      "Display asset matching to a platform profile is heuristic because no explicit foreign key exists.",
      "Ground operations and TTC sources contain no satellite assignment records.",
      "Reference stars remain semantically unlinked because the source defines no satellite relationship."
    ],
    "dataQualityNotes": [
      "Satellite profile NORAD identifiers mix strings and numbers.",
      "O3b profile nesting differs from the OneWeb and Starlink profiles.",
      "Some source strings contain mojibake and require normalization before object import.",
      "Communication-band names are dynamic object keys and require normalization.",
      "Display asset identifiers vary in case and sometimes include a filename extension."
    ],
    "regressionTags": [
      "model",
      "satellite",
      "world",
      "simple",
      "v2",
      "json-source",
      "metallic",
      "grid",
      "source-traceable"
    ]
  },
